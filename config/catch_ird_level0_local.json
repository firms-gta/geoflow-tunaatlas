{
  "profile": {
    "id": "tuna-atlas-catch",
    "mode": "entity",
    "project": "FIRMS Tuna Atlas",
    "organization": "FIRMS Tuna Atlas",
    "logos": [
      "http://firms.fao.org/figis/website/assets/images/templates/firms/firms_banner.gif",
      "https://www.blue-cloud.org/sites/default/files/styles/logo_small/public/FAO_2lines_500x500_1.png?itok=igwPSL5v",
      "https://en.ird.fr/sites/ird_fr/files/2019-08/logo_IRD_2016_BLOC_UK_COUL.png"
    ],
    "options": {
      "line_separator": "_\n"
    }
  },
  "metadata": {
    "entities" : [
      {
        "handler": "csv",
        "source": "config/geoflow_entities_tuna_global_datasets_ird_level0 - 2026_worfklow_catch_level0.csv"
      }
    ],
    "contacts" : [
      {
        "handler": "gsheet",
        "source": "https://docs.google.com/spreadsheets/d/1DtGR8cHAkro12DOFZn40cehfU9LoI9l7wVUCHfHH-xY/edit?usp=sharing"
      }
    ]
  },
  "software": [
	{
		"id": "my-database-write",
		"type": "output",
		"software_type": "dbi",
		"parameters": {
			"drv": "PostgreSQL",
			"user": "{{DB_USER}}",
			"password": "{{DB_PASSWORD}}",
			"host": "{{DB_HOST}}",
			"port": "{{DB_PORT}}",
			"dbname": "{{DB_NAME}}"
		},
		"properties" : {}
	}
  ],
  "actions": [
    
    {
      "id": "load_dataset",
      "script": "../R/tunaatlas_actions/load_dataset.R",
      "run": true,
      "options": {
        "upload_to_db_public": false,
        "upload_to_db": false,
        "create_materialized_view" : false,
        "add_sql_comments" : false,
        "upload_to_googledrive" : false,
        "save_local_path": "../../../../data/GTA_2026/dataoutputGTA/",
        "save_local_overwrite": true
      }
    }
    
  ]
}
