{
  "profile": {
	"id": "tunaatlas-qa",
	"mode": "entity",
	"project": "FIRMS Tuna Atlas",
	"organization": "FIRMS Tuna Atlas",
	"logos": [
		"http://firms.fao.org/figis/website/assets/images/templates/firms/firms_banner.gif",
		"http://www.fao.org/fileadmin/templates/family-farming-decade/images/FAO-IFAD-Logos/FAO-Logo-EN.svg",
		"http://www.umr-marbec.fr/images/logo-ird-en.png"
	],
	"options": {
		"line_separator": "_\n"
	}
  },
  "metadata": {
    "entities": [
		{
		  "handler": "csv",
		  "source": "config/geoflow_entities_tuna_codelists.csv"
		}
	],
    "contacts" : []
  },
  "software": [
	{
		"id": "tunaatlas-db-write",
		"type": "output",
		"software_type": "dbi",
		"parameters": {
			"drv": "PostgreSQL",
			"user": "{{DB_USER}}",
			"password": "{{DB_PASSWORD}}",
			"host": "{{DB_HOST}}",
			"port": "{{DB_PORT}}",
			"dbname": "{{DB_NAME}}"
		},
		"properties" : {
			"user_readonly": "{{DB_USER_READONLY}}",
			"onstart_r": {
				"script": "../R/tunaatlas_scripts/deploy_database_model.R",
				"fun": "deploy_database_model"
			},
     "onstart_r": {
				"script": "../R/tunaatlas_scripts/download_iccat_gpkg.R",
				"fun": "deploy_database_model"
			}
		},
		"properties" : {
			"user_readonly": "{{DB_USER_READONLY}}",
			"onend_r": {
				"script": "../R/tunaatlas_scripts/create_grid_views.R",
				"fun": "deploy_database_model"
			}
		}
	},
	{
		"id": "tunaatlas-db-read",
		"type": "input",
		"software_type": "dbi",
		"parameters": {
			"drv": "PostgreSQL",
			"user": "{{DB_USER}}",
			"password": "{{DB_PASSWORD}}",
			"host": "{{DB_HOST}}",
			"port": "{{DB_PORT}}",
			"dbname": "{{DB_NAME}}"
		},
		"properties" : {
		}
	}
  ],
  "actions": [
	{
		"id": "load_codelist",
		"script": "../R/tunaatlas_actions/load_codelist.R",
		"run": true
	  
	}
  ]
}
